function openProductDetail(id){
    let p=products.find(x=>x.id===id);if(!p)return;
    if(p.postUrl){ window.location.href = p.postUrl; return; }
    let imgs=p.images&&p.images.length>0?p.images:["https://via.placeholder.com/400"];
    let gal=imgs.map((img,i)=>`<img src="${img}" class="${i===0?'active':''}" onclick="changeMainImage(this,'${img}')" alt="">`).join('');
    document.getElementById('modalBody').innerHTML=`<div class="detail-grid"><div><img id="mainProductImage" class="main-image" src="${imgs[0]}" alt="${p.name}"><div class="product-gallery">${gal}</div></div><div><h2>${p.name}</h2><p style="color:#dc2626;font-weight:700;">${p.category.toUpperCase()} ${p.assorted?'· Assorted Colors':''}</p><div class="rating">${'★'.repeat(Math.floor(p.rating))}${'☆'.repeat(5-Math.floor(p.rating))} (${p.rating})</div><p>${p.desc||'Premium audio experience.'}</p><div class="price"><span class="current-price">PKR ${p.price}</span><span class="old-price">PKR ${p.oldPrice}</span></div><button class="add-to-cart-large" onclick="addToCart(${p.id});closeModal()"><i class="fas fa-cart-plus"></i> Add to Cart</button></div></div>`;
