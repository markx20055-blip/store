    g.innerHTML=f.map(p=>{
        let m=p.images&&p.images.length>0?p.images[0]:"https://via.placeholder.com/300";
        let clickAction = p.postUrl ? `location.href='${p.postUrl}'` : `openProductDetail(${p.id})`;
        return`<div class="product-card" onclick="${clickAction}"><img class="product-img" src="${m}" alt="${p.name}"><div class="product-info"><div class="product-category">${p.category.toUpperCase()} ${p.assorted?'🎨':''}</div><div class="product-title">${p.name}</div><div class="rating">${'★'.repeat(Math.floor(p.rating))}${'☆'.repeat(5-Math.floor(p.rating))} (${p.rating})</div><div class="price"><span class="current-price">PKR ${p.price}</span><span class="old-price">PKR ${p.oldPrice}</span></div><button class="btn-add" onclick="event.stopPropagation();addToCart(${p.id})">Add to Cart</button></div></div>`;
    }).join('');
}
function renderFeatured(){
    let f=products.slice(0,6);let g=document.getElementById('featuredGrid');if(!g)return;
