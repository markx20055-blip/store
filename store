// Load products from Blogger post with label "productjson"
function loadData() {
  var feedUrl = location.protocol + '//' + location.host + '/feeds/posts/default/-/productjson?alt=json&max-results=1&orderby=published&' + Date.now();
  fetch(feedUrl)
    .then(function(response) { return response.json(); })
    .then(function(data) {
      if (data.feed && data.feed.entry && data.feed.entry.length > 0) {
        var entry = data.feed.entry[0];
        currentPostId = entry.id.$t.split('post-')[1];
        var content = entry.content.$t;
        content = content.replace(/<br\s*\/?>/gi,'').replace(/&nbsp;/g,' ').replace(/&amp;/g,'&').trim();
        try {
          var newProds = JSON.parse(content);
          if (Array.isArray(newProds) && newProds.length > 0) {
            products = newProds;
            localStorage.setItem('shamain_products_v2', JSON.stringify(products));
          } else {
            throw new Error('Empty array');
          }
        } catch(e) {
          console.warn('Post content is not valid JSON, falling back.');
          useFallbackProducts();
        }
      } else {
        currentPostId = null;
        useFallbackProducts();
      }
    })
    .catch(function() {
      currentPostId = null;
      useFallbackProducts();
    })
    .finally(function() {
      var c = localStorage.getItem('shamain_cart');
      cart = c ? JSON.parse(c) : [];
      buildSliders();
      renderShop();
      renderFeatured();
      updateCartUI();
      showPage('home');
      fetchRecentPosts(); // for SEO content
      if (window.location.hash.startsWith('#product-')) {
        var id = parseInt(window.location.hash.split('-')[1]);
        if (!isNaN(id)) openProductDetail(id);
      }
    });
}

function useFallbackProducts() {
  var s = localStorage.getItem('shamain_products_v2');
  products = s ? JSON.parse(s) : [...defaultProducts];
}

function saveProducts() {
  localStorage.setItem('shamain_products_v2', JSON.stringify(products));
}
function saveCart() {
  localStorage.setItem('shamain_cart', JSON.stringify(cart));
  updateCartUI();
}

// Fetch recent blog posts (SEO boost)
function fetchRecentPosts() {
  var script = document.createElement('script');
  script.src = '/feeds/posts/default?max-results=4&alt=json-in-script&callback=displayRecentPosts';
  document.body.appendChild(script);
}
function displayRecentPosts(data) {
  var container = document.getElementById('recentPostsGrid');
  if (!container) return;
  var entries = data.feed.entry || [];
  var html = '';
  entries.forEach(function(entry) {
    var title = entry.title.$t;
    var link = '';
    for (var i=0; i<entry.link.length; i++) {
      if (entry.link[i].rel === 'alternate') { link = entry.link[i].href; break; }
    }
    var img = '';
    if (entry.media$thumbnail && entry.media$thumbnail.url) {
      img = entry.media$thumbnail.url.replace('s72-c', 's300');
    } else {
      img = 'https://via.placeholder.com/300';
    }
    var snippet = entry.summary ? entry.summary.$t.replace(/<[^>]+>/g,'').substring(0, 120) : '';
    html += `<div class="product-card" onclick="location.href='${link}'"><img class="product-img" src="${img}" alt="${title}"><div class="product-info"><div class="product-title">${title}</div><p style="font-size:13px;color:#6b7280;">${snippet}...</p></div></div>`;
  });
  if (html) {
    container.innerHTML = html;
  } else {
    container.innerHTML = '<p>No blog posts yet. <a href="/p/about-us.html">Learn more about us</a>.</p>';
  }
}

let currentFilter='all',searchTerm='';
