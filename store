function changeMainImage(el,src){document.getElementById('mainProductImage').src=src;document.querySelectorAll('.product-gallery img').forEach(i=>i.classList.remove('active'));el.classList.add('active');}
function updateCartUI(){
    let cnt=cart.reduce((s,i)=>s+i.quantity,0);document.getElementById('cartCount').innerText=cnt;
    let c=document.getElementById('cartItemsList');if(!c)return;
    if(cart.length===0)c.innerHTML='<div style="padding:40px;text-align:center;">Cart empty</div>';
    else c.innerHTML=cart.map(item=>{let img=item.images&&item.images.length>0?item.images[0]:"https://via.placeholder.com/70";return`<div class="cart-item"><img class="cart-item-img" src="${img}"><div style="flex:1"><strong>${item.name}</strong><div>PKR ${item.price}</div><div class="cart-qty"><button onclick="updateQty(${item.id},-1)">-</button><span>${item.quantity}</span><button onclick="updateQty(${item.id},1)">+</button></div></div><button style="color:#dc2626;background:none;border:none;cursor:pointer;" onclick="removeCartItem(${item.id})"><i class="fas fa-trash"></i></button></div>`;}).join('');
    let tot=cart.reduce((s,i)=>s+(i.price*i.quantity),0);document.getElementById('cartTotal').innerText=`PKR ${tot}`;
    saveCart();
}
window.updateQty=(id,d)=>{let i=cart.findIndex(x=>x.id===id);if(i!==-1){cart[i].quantity+=d;if(cart[i].quantity<=0)cart.splice(i,1);updateCartUI();renderShop();renderFeatured();}};
window.removeCartItem=(id)=>{cart=cart.filter(i=>i.id!==id);updateCartUI();renderShop();renderFeatured();};
window.addToCart=(id)=>{let p=products.find(x=>x.id===id);if(!p)return;let ex=cart.find(i=>i.id===id);if(ex)ex.quantity++;else cart.push({...p,quantity:1});updateCartUI();renderShop();renderFeatured();};

